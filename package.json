{
  "name": "@greenlight/monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "pnpm --filter @greenlight/server dev",
    "dev:web": "pnpm --filter @greenlight/web dev",
    "dev:desktop": "node scripts/dev-desktop.mjs",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "build:server": "pnpm --filter @greenlight/server build",
    "deploy:server": "pnpm --filter @greenlight/server run deploy",
    "dist:mac": "pnpm run build:server && pnpm run deploy:server && pnpm --filter @greenlight/web build && pnpm --filter @greenlight/desktop build && pnpm --filter @greenlight/desktop run dist:mac",
    "lint": "biome lint .",
    "fmt": "biome format --write .",
    "fmt:check": "biome format ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@effect/language-service": "latest",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@10.28.2"
}
